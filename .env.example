# YouTube Publisher Configuration

# Claude API key (for AI-generated descriptions and social posts)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server settings
YTP_HOST=127.0.0.1
YTP_PORT=8008

# Data directory (default: ~/.youtube-publisher)
# YTP_DATA_DIR=/path/to/data

# Background job intervals
YTP_COMMENT_CHECK_MINUTES=30
YTP_CAPTION_CHECK_MINUTES=15
