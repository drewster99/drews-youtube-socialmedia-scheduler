# YouTube Publisher Configuration

# Claude API key: NOT configured here. It is stored only in the system Keychain
# (encrypted-file fallback on non-macOS) — set it from the Settings page in the
# web UI. Secrets are never read from env vars / .env, by design.

# Claude model to use
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server settings
DYS_HOST=127.0.0.1
DYS_PORT=8008

# Data directory (default: ~/.yt-scheduler)
# DYS_DATA_DIR=/path/to/data

# Background job intervals
DYS_COMMENT_CHECK_MINUTES=30
DYS_CAPTION_CHECK_MINUTES=15

# Optional override for the Threads OAuth redirect "bounce" page. Defaults to
# https://nuclearcyborg.com/apps/scheduler/callback-threads-redirect (a static
# page that forwards ?code&state back to /api/oauth/threads/callback — source in
# cloudflare/). Only set this if you host the bounce page somewhere else.
# DYS_THREADS_REDIRECT_URL=https://example.com/apps/scheduler/callback-threads-redirect

# Legacy YTP_* names are still honored as a fallback.
